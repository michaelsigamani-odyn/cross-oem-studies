{
  "title": "Cross-OEM Failover",
  "uid": "cross-oem",
  "schemaVersion": 38,
  "version": 1,
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Node Status",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "router_status",
          "legendFormat": "{{node}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "green", "value": 1 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Batch Throughput (jobs/min)",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "rate(router_jobs_total[1m])",
          "legendFormat": "{{node}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Latency (p50/p95/p99)",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "router_latency_p50_ms",
          "legendFormat": "p50 {{node}}",
          "refId": "A"
        },
        {
          "expr": "router_latency_p95_ms",
          "legendFormat": "p95 {{node}}",
          "refId": "B"
        },
        {
          "expr": "router_latency_p99_ms",
          "legendFormat": "p99 {{node}}",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms"
        },
        "overrides": []
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Gateway Availability % (SLO >= 99.9%)",
      "datasource": {
        "type": "cloudwatch",
        "uid": "cloudwatch"
      },
      "targets": [
        {
          "namespace": "odyn-cross-oem",
          "metricName": "availability",
          "statistic": "Average",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": 0.0 },
              { "color": "green", "value": 0.999 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Batch Success Rate (SLO >= 99.5%)",
      "datasource": {
        "type": "cloudwatch",
        "uid": "cloudwatch"
      },
      "targets": [
        {
          "namespace": "odyn-cross-oem",
          "metricName": "batch_reliability",
          "statistic": "Average",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": 0.0 },
              { "color": "green", "value": 0.995 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Failover RTO (SLO <= 30s)",
      "datasource": {
        "type": "cloudwatch",
        "uid": "cloudwatch"
      },
      "targets": [
        {
          "namespace": "odyn-cross-oem",
          "metricName": "failover_rto_seconds",
          "statistic": "Average",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": 0.0 },
              { "color": "red", "value": 30.0 }
            ]
          }
        },
        "overrides": []
      }
    }
  ],
  "templating": {
    "list": []
  }
}
